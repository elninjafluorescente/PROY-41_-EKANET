{# Ilustraciones SVG de categoría — copiadas del handoff de Claude Design.
   Cada macro acepta variant ('light'|'dark'). Sólo geometría — sin photos. #}

{# SWITCH — rackable unit con puertos y LEDs #}
{% macro switch(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set led = dark ? 'oklch(0.85 0.16 140)' : 'oklch(0.62 0.17 140)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  {% set blue = 'oklch(0.65 0.09 265)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-sw-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-sw-{{ variant }})"/>
    <rect x="20" y="55" width="160" height="40" rx="3" fill="{{ body }}"/>
    <rect x="20" y="55" width="160" height="40" rx="3" fill="none" stroke="{{ gold }}" stroke-width="0.5" opacity="0.4"/>
    <rect x="26" y="62" width="22" height="10" rx="1" fill="{{ body2 }}"/>
    <circle cx="38" cy="80" r="1.5" fill="{{ led }}"/>
    <circle cx="44" cy="80" r="1.5" fill="{{ gold }}"/>
    {% for i in 0..7 %}
      <g transform="translate({{ 60 + i*14 }}, 62)">
        <rect width="10" height="14" rx="1" fill="{{ body2 }}"/>
        <rect x="1" y="1" width="8" height="3" fill="{{ body }}"/>
        <circle cx="3" cy="11" r="0.8" fill="{{ i < 3 ? led : line }}"/>
        <circle cx="7" cy="11" r="0.8" fill="{{ i < 2 ? gold : line }}"/>
      </g>
    {% endfor %}
    <path d="M 70 76 Q 40 110, 65 130" fill="none" stroke="{{ blue }}" stroke-width="1.5"/>
    <circle cx="65" cy="130" r="2" fill="{{ blue }}"/>
  </svg>
{% endmacro %}

{# FIBER — bobina con cable #}
{% macro fiber(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  {% set blue = 'oklch(0.65 0.09 265)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-fb-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-fb-{{ variant }})"/>
    <ellipse cx="100" cy="70" rx="50" ry="42" fill="{{ body }}"/>
    <ellipse cx="100" cy="70" rx="46" ry="38" fill="none" stroke="{{ gold }}" stroke-width="0.6" opacity="0.5"/>
    <ellipse cx="100" cy="70" rx="18" ry="14" fill="{{ body2 }}"/>
    <circle cx="100" cy="70" r="3" fill="{{ gold }}"/>
    {% for r in [30, 34, 38, 42, 46] %}
      <ellipse cx="100" cy="70" rx="{{ r }}" ry="{{ r * 0.84 }}" fill="none" stroke="{{ line }}" stroke-width="0.4" opacity="0.4"/>
    {% endfor %}
    <path d="M 100 24 Q 150 10, 180 40" fill="none" stroke="{{ gold }}" stroke-width="1.5"/>
    <path d="M 100 24 Q 150 10, 180 40" fill="none" stroke="{{ blue }}" stroke-width="0.6" opacity="0.8" stroke-dasharray="2 2"/>
    <circle cx="180" cy="40" r="2.5" fill="{{ gold }}"/>
    <circle cx="180" cy="40" r="5" fill="{{ gold }}" opacity="0.25"/>
  </svg>
{% endmacro %}

{# RACK — armario 19" #}
{% macro rack(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set led = dark ? 'oklch(0.85 0.16 140)' : 'oklch(0.62 0.17 140)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-rk-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-rk-{{ variant }})"/>
    <rect x="62" y="14" width="76" height="112" rx="2" fill="{{ body }}"/>
    <rect x="62" y="14" width="76" height="112" rx="2" fill="none" stroke="{{ gold }}" stroke-width="0.5" opacity="0.35"/>
    {% for i in 0..8 %}
      {% set y = 22 + i * 11 %}
      {% set filled = i in [0, 2, 3, 5, 7] %}
      <rect x="68" y="{{ y }}" width="64" height="9" rx="1" fill="{{ filled ? body2 : 'transparent' }}" stroke="{{ line }}" stroke-width="0.5"/>
      {% if filled %}
        <circle cx="72" cy="{{ y + 4.5 }}" r="0.8" fill="{{ led }}"/>
        <circle cx="75" cy="{{ y + 4.5 }}" r="0.8" fill="{{ gold }}"/>
        {% if i == 2 %}
          {% for p in 0..7 %}
            <rect x="{{ 82 + p*5 }}" y="{{ y + 2 }}" width="3" height="5" fill="{{ body }}"/>
          {% endfor %}
        {% endif %}
      {% endif %}
    {% endfor %}
    <circle cx="66" cy="120" r="1.5" fill="{{ gold }}"/>
    <circle cx="134" cy="120" r="1.5" fill="{{ gold }}"/>
  </svg>
{% endmacro %}

{# SAI / UPS #}
{% macro sai(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set led = dark ? 'oklch(0.85 0.16 140)' : 'oklch(0.62 0.17 140)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-sa-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-sa-{{ variant }})"/>
    <rect x="70" y="30" width="60" height="96" rx="3" fill="{{ body }}"/>
    <rect x="70" y="30" width="60" height="96" rx="3" fill="none" stroke="{{ gold }}" stroke-width="0.5" opacity="0.4"/>
    <rect x="80" y="44" width="40" height="20" rx="2" fill="{{ body2 }}"/>
    <text x="100" y="58" text-anchor="middle" font-family="monospace" font-size="7" fill="{{ gold }}">220V</text>
    <circle cx="80" cy="74" r="2" fill="{{ led }}"/>
    <circle cx="90" cy="74" r="2" fill="{{ gold }}"/>
    <circle cx="100" cy="74" r="2" fill="{{ line }}"/>
    <circle cx="110" cy="74" r="2" fill="{{ line }}"/>
    <circle cx="120" cy="74" r="2" fill="{{ line }}"/>
    <circle cx="100" cy="94" r="6" fill="none" stroke="{{ gold }}" stroke-width="1"/>
    <line x1="100" y1="89" x2="100" y2="94" stroke="{{ gold }}" stroke-width="1.2" stroke-linecap="round"/>
    {% for x in [78, 94, 110] %}
      <rect x="{{ x }}" y="108" width="12" height="10" rx="1" fill="{{ body2 }}"/>
      <circle cx="{{ x + 3 }}" cy="113" r="1" fill="{{ body }}"/>
      <circle cx="{{ x + 9 }}" cy="113" r="1" fill="{{ body }}"/>
    {% endfor %}
    <path d="M 145 55 l -4 10 l 4 0 l -3 10" fill="none" stroke="{{ gold }}" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
{% endmacro %}

{# CABLE — ethernet en bobina #}
{% macro cable(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set blue = 'oklch(0.65 0.09 265)' %}
  {% set blueDeep = 'oklch(0.52 0.11 265)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-cb-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-cb-{{ variant }})"/>
    {% for r in [50, 42, 34, 26] %}
      <circle cx="90" cy="78" r="{{ r }}" fill="none" stroke="{{ loop.index0 is even ? blue : blueDeep }}" stroke-width="5"/>
    {% endfor %}
    <g transform="translate(140, 40) rotate(15)">
      <rect x="0" y="0" width="24" height="16" rx="1" fill="{{ body }}"/>
      <rect x="4" y="-3" width="16" height="4" fill="{{ gold }}"/>
      <rect x="3" y="3" width="18" height="8" fill="{{ body2 }}"/>
      {% for i in 0..7 %}
        <rect x="{{ 4 + i*2 }}" y="5" width="1" height="4" fill="{{ gold }}"/>
      {% endfor %}
    </g>
    <path d="M 135 54 Q 125 60, 120 72" fill="none" stroke="{{ blueDeep }}" stroke-width="4"/>
  </svg>
{% endmacro %}

{# ELECTRIC — fila de magnetotérmicos #}
{% macro elec(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-el-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-el-{{ variant }})"/>
    <rect x="20" y="60" width="160" height="4" fill="{{ body2 }}"/>
    {% for i in 0..6 %}
      {% set x = 30 + i * 20 %}
      {% set on = i in [0, 1, 3, 4, 6] %}
      <g transform="translate({{ x }}, 34)">
        <rect width="14" height="60" rx="1.5" fill="{{ body }}"/>
        <rect y="2" width="14" height="8" fill="{{ body2 }}"/>
        <rect x="4" y="{{ on ? 14 : 36 }}" width="6" height="14" rx="1" fill="{{ on ? gold : line }}"/>
        <circle cx="7" cy="{{ on ? 21 : 43 }}" r="1.2" fill="{{ body }}"/>
        <text x="7" y="56" text-anchor="middle" font-family="monospace" font-size="5" fill="{{ line }}">C16</text>
      </g>
    {% endfor %}
    <path d="M 30 100 L 170 100" stroke="{{ gold }}" stroke-width="1" opacity="0.6" stroke-dasharray="2 2"/>
  </svg>
{% endmacro %}

{# CONNECTIVITY — AP con señal #}
{% macro connect(variant) %}
  {% set dark = variant == 'dark' %}
  {% set bg = dark ? 'oklch(0.26 0.018 260)' : 'oklch(0.96 0.01 260)' %}
  {% set body = dark ? 'oklch(0.18 0.015 260)' : 'oklch(0.32 0.012 260)' %}
  {% set body2 = dark ? 'oklch(0.22 0.015 260)' : 'oklch(0.42 0.012 260)' %}
  {% set line = dark ? 'oklch(0.35 0.018 260)' : 'oklch(0.85 0.008 260)' %}
  {% set led = dark ? 'oklch(0.85 0.16 140)' : 'oklch(0.62 0.17 140)' %}
  {% set blue = 'oklch(0.65 0.09 265)' %}
  {% set gold = 'oklch(0.78 0.14 78)' %}
  <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
    <rect width="200" height="140" fill="{{ bg }}"/>
    <defs><pattern id="dots-cn-{{ variant }}" width="8" height="8" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="0.6" fill="{{ line }}" opacity="0.6"/>
    </pattern></defs>
    <rect width="200" height="140" fill="url(#dots-cn-{{ variant }})"/>
    <rect x="75" y="75" width="50" height="38" rx="3" fill="{{ body }}"/>
    <circle cx="100" cy="92" r="6" fill="{{ gold }}" opacity="0.3"/>
    <circle cx="100" cy="92" r="3" fill="{{ gold }}"/>
    <circle cx="85" cy="105" r="1.2" fill="{{ led }}"/>
    <circle cx="92" cy="105" r="1.2" fill="{{ led }}"/>
    <circle cx="100" cy="105" r="1.2" fill="{{ gold }}"/>
    <rect x="72" y="54" width="2" height="22" fill="{{ body2 }}"/>
    <circle cx="73" cy="52" r="2" fill="{{ blue }}"/>
    <rect x="126" y="54" width="2" height="22" fill="{{ body2 }}"/>
    <circle cx="127" cy="52" r="2" fill="{{ blue }}"/>
    {% for r in [18, 28, 38] %}
      <path d="M {{ 100 - r }} 40 A {{ r }} {{ r }} 0 0 1 {{ 100 + r }} 40"
            fill="none" stroke="{{ gold }}" stroke-width="1.2"
            opacity="{{ 0.8 - loop.index0 * 0.22 }}"
            stroke-dasharray="{{ loop.index0 == 2 ? '2 3' : '' }}"/>
    {% endfor %}
  </svg>
{% endmacro %}

{# Selector por slug — usado por home.twig #}
{% macro byKey(key, variant) %}
  {% import _self as illu %}
  {% if key == 'switch' %}{{ illu.switch(variant) }}
  {% elseif key == 'fiber' %}{{ illu.fiber(variant) }}
  {% elseif key == 'rack' %}{{ illu.rack(variant) }}
  {% elseif key == 'sai' %}{{ illu.sai(variant) }}
  {% elseif key == 'cable' %}{{ illu.cable(variant) }}
  {% elseif key == 'elec' %}{{ illu.elec(variant) }}
  {% elseif key == 'connect' %}{{ illu.connect(variant) }}
  {% endif %}
{% endmacro %}
