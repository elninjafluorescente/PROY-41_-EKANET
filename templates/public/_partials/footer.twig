<footer class="ek-footer">
<div class="ek-footer__inner">
    <div class="ek-footer__cols">
        <div>
            <a href="/" class="ek-logo" aria-label="{{ shop.name }} · Inicio">
                <svg width="28" height="28" viewBox="0 0 40 40" aria-hidden="true">
                    <circle cx="20" cy="6" r="3.2" fill="var(--ek-gold)"/>
                    <circle cx="13" cy="18" r="3.2" fill="var(--ek-blue)"/>
                    <circle cx="27" cy="18" r="3.2" fill="var(--ek-blue)"/>
                    <circle cx="20" cy="27" r="3.2" fill="var(--ek-blue)"/>
                </svg>
                <span class="ek-logo__name" style="color:#fff">ekanet</span>
            </a>
            <div style="margin-top:14px; font-size:12px; line-height:1.6">
                Componentes profesionales de telecomunicaciones.<br>
                {{ shop.city|default('Pamplona · Madrid · Barcelona') }}
            </div>
        </div>

        <div class="ek-footer__col">
            <div class="ek-footer__col-title">Catálogo</div>
            {% for c in footer_categories|default([
                {name:'Racks y armarios', slug:'racks'},
                {name:'Cableado estructurado', slug:'cableado'},
                {name:'Fibra óptica', slug:'fibra-optica'},
                {name:'SAIs', slug:'sai'},
                {name:'Material eléctrico', slug:'material-electrico'}
            ]) %}
                <a href="/{{ c.slug }}">{{ c.name }}</a>
            {% endfor %}
        </div>

        <div class="ek-footer__col">
            <div class="ek-footer__col-title">Profesional</div>
            <a href="/cuenta-pro">Cuenta Pro</a>
            <a href="/presupuestos">Presupuestos</a>
            <a href="/proyectos">Proyectos</a>
            <a href="/facturacion">Facturación</a>
        </div>

        <div class="ek-footer__col">
            <div class="ek-footer__col-title">Empresa</div>
            <a href="/sobre-nosotros">Sobre {{ shop.name }}</a>
            <a href="/marcas">Marcas</a>
            <a href="/blog">Blog técnico</a>
            <a href="/contacto">Contacto</a>
        </div>

        <div class="ek-footer__col">
            <div class="ek-footer__col-title">Ayuda</div>
            <a href="/envios">Envíos</a>
            <a href="/devoluciones">Devoluciones</a>
            <a href="/condiciones">Términos</a>
            <a href="/privacidad">Privacidad</a>
            <a href="/cookies">Cookies</a>
        </div>
    </div>

    <div class="ek-footer__bottom">
        <span class="mono">© {{ "now"|date("Y") }} {{ shop.name|upper }}{% if shop.cif %} · CIF {{ shop.cif }}{% endif %}</span>
        <span class="mono">[ NODO · {{ shop.city|default('PAMPLONA')|upper }} ]</span>
    </div>
</div>
</footer>
