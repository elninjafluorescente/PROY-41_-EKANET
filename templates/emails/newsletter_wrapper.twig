<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ subject }}</title>
</head>
<body style="margin:0; padding:0; background:#f4f5f8; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color:#1a1a26;">
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background:#f4f5f8; padding:24px 0;">
<tr>
<td align="center">
    <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0"
           style="max-width:600px; background:#ffffff; border-radius:8px; overflow:hidden;">
        <tr>
            <td style="background:linear-gradient(90deg, #5a6dba 0%, #5a6dba 70%, #e09a2e 70%, #e09a2e 100%); height:4px; line-height:4px; font-size:0;">&nbsp;</td>
        </tr>
        <tr>
            <td style="padding:24px 28px 8px;">
                <div style="font-size:18px; font-weight:bold; color:#1a1a26;">{{ shop_name }}</div>
            </td>
        </tr>
        <tr>
            <td style="padding:8px 28px 28px; font-size:14px; line-height:1.6; color:#1a1a26;">
                {{ body_html|raw }}
            </td>
        </tr>
        <tr>
            <td style="padding:18px 28px; background:#f4f5f8; font-size:11px; color:#6b6e7a; border-top:1px solid #ecedf0;">
                {{ shop_name }} · {{ shop_email }}{% if shop_phone %} · {{ shop_phone }}{% endif %}<br>
                Recibes este email porque te suscribiste a nuestra newsletter ({{ recipient_email }}).
            </td>
        </tr>
    </table>
</td>
</tr>
</table>
</body>
</html>
