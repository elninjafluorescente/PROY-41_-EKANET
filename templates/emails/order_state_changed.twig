{% extends 'emails/_layout.twig' %}

{% block content %}
<h2 style="margin: 0 0 14px; font-size: 20px; color:#1a1a26;">Tu pedido cambió de estado</h2>

<p>Hola {{ customer_name }},</p>

<p>Te informamos de un cambio en el estado de tu pedido <strong style="font-family: 'JetBrains Mono', monospace;">{{ order.reference }}</strong>:</p>

<table cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f4f5f8; border-radius: 6px; padding: 16px; margin: 18px 0;">
    <tr><td>
        <div style="font-size: 11px; letter-spacing: .12em; color:#6b6e7a; text-transform:uppercase; margin-bottom: 4px;">Nuevo estado</div>
        <div style="display:inline-block; padding: 6px 14px; border-radius: 20px; background: {{ state_color }}22; border: 1px solid {{ state_color }}; color: {{ state_color }}; font-weight: 600; font-size: 14px;">
            {{ state_name }}
        </div>
    </td></tr>
</table>

{% if shipping_number %}
<p><strong>Número de seguimiento:</strong> <span style="font-family: monospace">{{ shipping_number }}</span></p>
{% endif %}

<p style="margin-top: 22px;">
    <a href="{{ shop_url }}/mi-cuenta/pedidos/{{ order.id_order }}"
       style="display:inline-block; padding: 12px 24px; background: #5a6dba; color: white; text-decoration: none; border-radius: 4px; font-weight: 600;">
        Ver mi pedido
    </a>
</p>

<p style="margin-top: 26px; color: #6b6e7a; font-size: 13px;">
    Si tienes cualquier duda, responde a este email o contáctanos en {{ shop_email }}.
</p>
{% endblock %}
