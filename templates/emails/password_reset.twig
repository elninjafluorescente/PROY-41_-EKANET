{% extends 'emails/_layout.twig' %}

{% block content %}
<h2 style="margin: 0 0 14px; font-size: 20px; color:#1a1a26;">Restablecer tu contraseña</h2>

<p>Hola {{ name }},</p>

<p>Hemos recibido una solicitud para restablecer la contraseña de tu cuenta de {{ shop_name }}. Pulsa el botón de abajo para crear una nueva contraseña.</p>

<p style="margin: 26px 0;">
    <a href="{{ reset_url }}"
       style="display:inline-block; padding: 14px 28px; background: #5a6dba; color: white; text-decoration: none; border-radius: 4px; font-weight: 600;">
        Restablecer contraseña
    </a>
</p>

<p style="font-size: 12px; color: #6b6e7a; margin-top: 26px;">
    Si no funciona el botón, copia y pega este enlace en tu navegador:<br>
    <span style="color:#5a6dba; word-break: break-all;">{{ reset_url }}</span>
</p>

<p style="margin-top: 20px; padding-top: 16px; border-top: 1px solid #e5e7ec; font-size: 12px; color: #6b6e7a;">
    El enlace caduca en <strong>{{ valid_hours }} horas</strong>.
    Si tú no has solicitado este cambio, simplemente ignora este email — tu contraseña no se modificará.
</p>
{% endblock %}
