{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_marketing.twig' with {tab: 'pixeles'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo script' : 'Editar script' }}
        </h1>
        {% if mode == 'edit' %}<p class="ek-page-header__subtitle">ID #{{ item.id_tracking_script }}</p>{% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('pixeles') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('pixeles/nuevo')
          : admin_url('pixeles/' ~ item.id_tracking_script ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="ek-panel">
        <h2>Datos del script</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Nombre *</span>
                <input type="text" name="name" required maxlength="64" value="{{ item.name }}"
                       placeholder="ej. GA4 Producción">
            </label>

            <label class="ek-field">
                <span>Proveedor</span>
                <select name="provider">
                    {% for k, label in providers %}
                        <option value="{{ k }}" {{ item.provider == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Posición en el HTML</span>
                <select name="placement">
                    {% for k, label in placements %}
                        <option value="{{ k }}" {{ item.placement == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
                <small class="ek-field__hint">GA4/Meta Pixel suelen ir en &lt;head&gt;.</small>
            </label>

            <label class="ek-field">
                <span>ID de seguimiento</span>
                <input type="text" name="tracking_id" maxlength="128" value="{{ item.tracking_id|default('') }}"
                       placeholder="G-XXXXXXX, GTM-XXXXX, 1234567890…">
            </label>

            <label class="ek-field">
                <span>Entorno</span>
                <select name="environment">
                    {% for k, label in envs %}
                        <option value="{{ k }}" {{ item.environment == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Inyectar en el frontend</span>
                </label>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Código del script (HTML completo, incluye etiquetas &lt;script&gt;)</span>
                <textarea name="script_code" rows="14" class="mono" style="font-size:12px">{{ item.script_code|default('') }}</textarea>
                <small class="ek-field__hint">Pega el snippet tal cual te lo da el proveedor.</small>
            </label>
        </div>
    </div>

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('pixeles') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear script' : 'Guardar cambios' }}
        </button>
    </div>
</form>
{% endblock %}
