{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_marketing.twig' with {tab: 'banners'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Banners</h1>
        <p class="ek-page-header__subtitle">
            Banners gráficos del slider principal y bloques destacados.
        </p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('banners/nuevo') }}">+ Nuevo banner</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th style="width:80px">Imagen</th>
                <th>Título</th>
                <th>Posición</th>
                <th>Programación</th>
                <th style="width:80px">Estado</th>
                <th style="width:140px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for b in banners %}
            <tr>
                <td class="mono">{{ b.id_banner }}</td>
                <td>
                    {% if b.image_url %}
                        <img src="{{ b.image_url }}" alt="" style="width:60px; height:36px; object-fit:cover; border-radius:4px; border:1px solid var(--ek-line)">
                    {% else %}
                        <span class="ek-placeholder" style="display:inline-block; width:60px; height:36px; line-height:36px; text-align:center; font-size:9px;">SIN IMG</span>
                    {% endif %}
                </td>
                <td>
                    <strong>{{ b.title }}</strong>
                    {% if b.subtitle %}<br><span style="color:var(--ek-ink-3); font-size:12px">{{ b.subtitle }}</span>{% endif %}
                </td>
                <td><span class="ek-pill ek-pill--blue">{{ placements[b.placement]|default(b.placement) }}</span></td>
                <td style="font-size:12px; color: var(--ek-ink-3)">
                    {% if b.date_start or b.date_end %}
                        {{ b.date_start ? b.date_start|date('d/m/Y') : '∞' }}
                        →
                        {{ b.date_end ? b.date_end|date('d/m/Y') : '∞' }}
                    {% else %}—{% endif %}
                </td>
                <td>
                    {% if b.active %}
                        <span class="ek-badge ek-badge--ok">Activo</span>
                    {% else %}
                        <span class="ek-badge ek-badge--muted">Inactivo</span>
                    {% endif %}
                </td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('banners/' ~ b.id_banner ~ '/editar') }}">Editar</a>
                    <form method="post" action="{{ admin_url('banners/' ~ b.id_banner ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar el banner \'{{ b.title }}\'?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="7" class="ek-table__empty">No hay banners todavía.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
