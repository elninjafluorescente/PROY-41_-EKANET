{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_descuentos.twig' with {tab: 'precios'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Precios especiales</h1>
        <p class="ek-page-header__subtitle">
            Rebajas aplicadas directamente al producto en la ficha o por cantidad mínima.
            Pueden ser específicas para un cliente.
        </p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('precios_especiales/nuevo') }}">+ Nuevo precio</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Producto</th>
                <th>Cliente</th>
                <th>Tipo</th>
                <th>Reducción / precio fijo</th>
                <th style="width:90px">Cant. mín.</th>
                <th>Vigencia</th>
                <th style="width:140px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for r in rules %}
            <tr>
                <td class="mono">{{ r.id_specific_price }}</td>
                <td>
                    <strong>{{ r.product_name|default('—') }}</strong>
                    {% if r.reference %}<br><span class="mono" style="color:var(--ek-ink-3); font-size:11px">{{ r.reference }}</span>{% endif %}
                </td>
                <td style="font-size:12px">
                    {% if r.id_customer > 0 %}
                        {{ r.firstname }} {{ r.lastname }}
                    {% else %}
                        <span style="color: var(--ek-ink-3)">Todos</span>
                    {% endif %}
                </td>
                <td>
                    {% if r.price >= 0 %}
                        <span class="ek-pill ek-pill--gold">precio fijo</span>
                    {% elseif r.reduction_type == 'percentage' %}
                        <span class="ek-pill ek-pill--blue">% descuento</span>
                    {% else %}
                        <span class="ek-pill ek-pill--blue">€ descuento</span>
                    {% endif %}
                </td>
                <td class="mono">
                    {% if r.price >= 0 %}
                        {{ r.price|number_format(2, ',', '.') }} €
                    {% elseif r.reduction_type == 'percentage' %}
                        -{{ (r.reduction * 100)|number_format(0) }}%
                    {% else %}
                        -{{ r.reduction|number_format(2, ',', '.') }} €
                    {% endif %}
                </td>
                <td class="mono">{{ r.from_quantity }}</td>
                <td style="font-size:12px; color: var(--ek-ink-3)">
                    {{ r.from|date('d/m/Y') }} → {{ r.to|date('d/m/Y') }}
                </td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('precios_especiales/' ~ r.id_specific_price ~ '/editar') }}">Editar</a>
                    <form method="post" action="{{ admin_url('precios_especiales/' ~ r.id_specific_price ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar este precio especial?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="8" class="ek-table__empty">No hay precios especiales todavía.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
