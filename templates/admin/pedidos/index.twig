{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_pedidos.twig' with {tab: 'pedidos'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Pedidos</h1>
        <p class="ek-page-header__subtitle">Total: <strong>{{ total }}</strong> pedido{{ total == 1 ? '' : 's' }}.</p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('pedidos/nuevo') }}">+ Pedido manual</a>
    </div>
</div>

<form method="get" action="{{ admin_url('pedidos') }}" class="ek-search-bar">
    <input type="search" name="q" value="{{ search }}" placeholder="Buscar por referencia, cliente o email…">
    <select name="state" onchange="this.form.submit()">
        <option value="0">Todos los estados</option>
        {% for s in states %}
            <option value="{{ s.id_order_state }}" {{ s.id_order_state == state_filter ? 'selected' : '' }}>
                {{ s.name }}
            </option>
        {% endfor %}
    </select>
    <button type="submit" class="ek-btn ek-btn--ghost">Filtrar</button>
    {% if search or state_filter %}<a class="ek-btn ek-btn--ghost" href="{{ admin_url('pedidos') }}">Limpiar</a>{% endif %}
</form>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Referencia</th>
                <th>Cliente</th>
                <th style="width:100px">Pago</th>
                <th>Estado</th>
                <th style="width:120px; text-align:right">Total</th>
                <th>Fecha</th>
                <th style="width:90px">Factura</th>
                <th style="width:90px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for o in orders %}
            <tr>
                <td class="mono">{{ o.id_order }}</td>
                <td class="mono" style="font-size:12px">{{ o.reference|default('—') }}</td>
                <td>
                    <strong>{{ o.firstname }} {{ o.lastname }}</strong>
                    {% if o.company %}<span class="ek-pill ek-pill--blue">B2B</span>{% endif %}
                    <br><span class="mono" style="color:var(--ek-ink-3); font-size:11px">{{ o.email }}</span>
                </td>
                <td style="font-size:12px">{{ o.payment }}</td>
                <td>
                    <span class="ek-badge" style="background: {{ o.state_color }}22; border-color: {{ o.state_color }}; color: {{ o.state_color }}">
                        {{ o.state_name|default('—') }}
                    </span>
                </td>
                <td class="mono" style="text-align:right">{{ o.total_paid_tax_incl|number_format(2, ',', '.') }} €</td>
                <td style="font-size:12px; color: var(--ek-ink-3)">{{ o.date_add|date('d/m/Y H:i') }}</td>
                <td class="mono" style="font-size:12px">{{ o.invoice_number > 0 ? o.invoice_number : '—' }}</td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('pedidos/' ~ o.id_order) }}">Ver</a>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="9" class="ek-table__empty">{{ search or state_filter ? 'Sin resultados.' : 'No hay pedidos todavía.' }}</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if pages > 1 %}
<nav class="ek-pagination">
    {% for i in 1..pages %}
        <a href="{{ admin_url('pedidos') }}?p={{ i }}{% if search %}&q={{ search|url_encode }}{% endif %}{% if state_filter %}&state={{ state_filter }}{% endif %}"
           class="ek-pagination__page {{ i == page ? 'is-active' : '' }}">{{ i }}</a>
    {% endfor %}
</nav>
{% endif %}
{% endblock %}
