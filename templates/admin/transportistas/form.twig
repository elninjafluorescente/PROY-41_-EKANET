{% extends 'admin/_layout.twig' %}

{% block content %}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo transportista' : 'Editar transportista' }}
        </h1>
        {% if mode == 'edit' %}
            <p class="ek-page-header__subtitle">ID #{{ item.id_carrier }}</p>
        {% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('transportistas') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('transportistas/nuevo')
          : admin_url('transportistas/' ~ item.id_carrier ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="ek-panel">
        <h2>Datos del transportista</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Nombre *</span>
                <input type="text" name="name" required maxlength="64" value="{{ item.name }}">
                <small class="ek-field__hint">Visible en el checkout (ej. SEUR, MRW, Correos Express).</small>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Plazo de entrega</span>
                <input type="text" name="delay" maxlength="512" value="{{ item.delay|default('') }}"
                       placeholder="ej. Entrega en 24/48 horas">
                <small class="ek-field__hint">Texto que verá el cliente.</small>
            </label>

            <label class="ek-field ek-field--wide">
                <span>URL de seguimiento</span>
                <input type="url" name="url" value="{{ item.url|default('') }}"
                       placeholder="https://transportista.com/tracking?id=@">
                <small class="ek-field__hint">Usa <code>@</code> donde irá el número de envío.</small>
            </label>

            <label class="ek-field">
                <span>Tipo de tarifa</span>
                <select name="shipping_method">
                    {% for k, label in methods %}
                        <option value="{{ k }}" {{ item.shipping_method == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Calidad del servicio (0-9)</span>
                <input type="number" name="grade" min="0" max="9" value="{{ item.grade|default(0) }}">
                <small class="ek-field__hint">9 = mejor. Usado para ordenar opciones.</small>
            </label>

            <label class="ek-field">
                <span>Envío gratis</span>
                <label class="ek-switch">
                    <input type="checkbox" name="is_free" value="1" {{ item.is_free ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Sin coste para el cliente</span>
                </label>
            </label>

            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Disponible en el checkout</span>
                </label>
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Límites del paquete</h2>
        <p class="ek-panel__hint">Si un pedido supera estos límites, el transportista no será una opción válida.</p>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Ancho máx. (cm)</span>
                <input type="number" name="max_width" min="0" value="{{ item.max_width|default(0) }}">
            </label>
            <label class="ek-field">
                <span>Alto máx. (cm)</span>
                <input type="number" name="max_height" min="0" value="{{ item.max_height|default(0) }}">
            </label>
            <label class="ek-field">
                <span>Profundidad máx. (cm)</span>
                <input type="number" name="max_depth" min="0" value="{{ item.max_depth|default(0) }}">
            </label>
            <label class="ek-field">
                <span>Peso máx. (kg)</span>
                <input type="text" name="max_weight" inputmode="decimal" value="{{ item.max_weight|default(0) }}">
                <small class="ek-field__hint">0 = sin límite.</small>
            </label>
        </div>
    </div>

    {# ===== Zonas atendidas ===== #}
    <div class="ek-panel" style="margin-top:16px">
        <h2>Zonas atendidas</h2>
        <p class="ek-panel__hint">
            Marca las zonas a las que este transportista hace entregas.
            <a href="{{ admin_url('zonas') }}">Gestionar zonas →</a>
        </p>
        <div class="ek-form__grid">
            {% for z in all_zones %}
                <label class="ek-switch">
                    <input type="checkbox" name="zones[]" value="{{ z.id_zone }}"
                           {{ z.id_zone in carrier_zones ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">{{ z.name }}</span>
                </label>
            {% else %}
                <p class="ek-field__hint">No hay zonas activas. Crea alguna en <a href="{{ admin_url('zonas') }}">Zonas geográficas</a>.</p>
            {% endfor %}
        </div>
    </div>

    {# ===== Tarifas (matriz zona × rango) ===== #}
    {% if mode == 'edit' and range_type %}
    <div class="ek-panel" style="margin-top:16px">
        <h2>Tarifas por {{ range_type == 'weight' ? 'peso' : 'importe' }}</h2>
        <p class="ek-panel__hint">
            Define los rangos abajo y rellena el precio para cada combinación zona × rango.
            Para tarifa plana: añade un único rango (ej. <span class="mono">0 → 99999</span>).
            <strong>Importante:</strong> guarda primero los rangos antes de poner precios.
        </p>

        {% if ranges|length > 0 and carrier_zones|length > 0 %}
        <div class="ek-table-wrap" style="margin-top:12px">
            <table class="ek-table">
                <thead>
                    <tr>
                        <th>Zona</th>
                        {% for r in ranges %}
                            <th class="mono" style="width:140px">
                                {{ r.delimiter1|number_format(2, ',', '.') }} — {{ r.delimiter2|number_format(2, ',', '.') }}
                                {{ range_type == 'weight' ? 'kg' : '€' }}
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for z in all_zones %}
                        {% if z.id_zone in carrier_zones %}
                        <tr>
                            <td><strong>{{ z.name }}</strong></td>
                            {% for r in ranges %}
                                <td>
                                    <input type="text" inputmode="decimal" class="mono"
                                           name="prices[{{ z.id_zone }}][{{ r.id_range }}]"
                                           value="{{ price_matrix[z.id_zone][r.id_range] is defined
                                               ? price_matrix[z.id_zone][r.id_range]|number_format(2, '.', '')
                                               : '' }}"
                                           placeholder="0.00"
                                           style="width:100px">
                                </td>
                            {% endfor %}
                        </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="ek-field__hint" style="margin-top:12px">
            {% if carrier_zones|length == 0 %}Marca antes alguna zona arriba.{% endif %}
            {% if ranges|length == 0 %}Añade al menos un rango abajo.{% endif %}
        </p>
        {% endif %}
    </div>
    {% endif %}

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('transportistas') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear transportista' : 'Guardar cambios' }}
        </button>
    </div>
</form>

{# ===== Gestión de rangos (formulario aparte para evitar anidamiento) ===== #}
{% if mode == 'edit' and range_type %}
<div class="ek-panel" style="margin-top:16px">
    <h2>Rangos de {{ range_type == 'weight' ? 'peso' : 'importe' }} para este transportista</h2>

    <div class="ek-table-wrap">
        <table class="ek-table">
            <thead>
                <tr>
                    <th style="width:60px">ID</th>
                    <th>Desde</th>
                    <th>Hasta</th>
                    <th style="width:100px; text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for r in ranges %}
                <tr>
                    <td class="mono">{{ r.id_range }}</td>
                    <td class="mono">{{ r.delimiter1|number_format(2, ',', '.') }} {{ range_type == 'weight' ? 'kg' : '€' }}</td>
                    <td class="mono">{{ r.delimiter2|number_format(2, ',', '.') }} {{ range_type == 'weight' ? 'kg' : '€' }}</td>
                    <td style="text-align:right">
                        <form method="post"
                              action="{{ admin_url('transportistas/' ~ item.id_carrier ~ '/rangos/' ~ range_type ~ '/' ~ r.id_range ~ '/eliminar') }}"
                              style="display:inline"
                              onsubmit="return confirm('¿Eliminar este rango y sus tarifas asociadas?');">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="ek-table__empty">No hay rangos. Añade el primero abajo.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <form method="post" class="ek-form" style="margin-top:16px"
          action="{{ admin_url('transportistas/' ~ item.id_carrier ~ '/rangos/nuevo') }}">
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <input type="hidden" name="range_type" value="{{ range_type }}">
        <h3 style="margin:0 0 12px 0">Añadir rango</h3>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Desde ({{ range_type == 'weight' ? 'kg' : '€' }})</span>
                <input type="text" name="range_from" inputmode="decimal" required value="0">
            </label>
            <label class="ek-field">
                <span>Hasta ({{ range_type == 'weight' ? 'kg' : '€' }})</span>
                <input type="text" name="range_to" inputmode="decimal" required value="99999">
            </label>
        </div>
        <div class="ek-form__actions">
            <button type="submit" class="ek-btn ek-btn--primary">+ Añadir rango</button>
        </div>
    </form>
</div>
{% elseif mode == 'edit' and not range_type %}
<div class="ek-panel" style="margin-top:16px">
    <h2>Tarifas</h2>
    <p class="ek-panel__hint">
        Este transportista usa <strong>tarifa por defecto</strong> (sin escalado por peso/importe).
        Si quieres tarifas distintas por zona, cambia "Tipo de tarifa" arriba a
        "Por peso del pedido" o "Por importe del pedido", guarda el transportista
        y vuelve aquí para configurar los rangos.
    </p>
</div>
{% endif %}
{% endblock %}
