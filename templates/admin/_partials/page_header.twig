{# Cabecera de página reutilizable: título + subtítulo + acciones a la derecha #}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">{{ title }}</h1>
        {% if subtitle is defined and subtitle %}
            <p class="ek-page-header__subtitle">{{ subtitle }}</p>
        {% endif %}
    </div>
    {% if actions is defined %}
        <div class="ek-page-header__actions">{{ actions|raw }}</div>
    {% endif %}
</div>
