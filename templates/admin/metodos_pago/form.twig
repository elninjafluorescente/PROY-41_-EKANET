{% extends 'admin/_layout.twig' %}

{% block content %}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo método de pago' : 'Editar método de pago' }}
        </h1>
        {% if mode == 'edit' %}
            <p class="ek-page-header__subtitle">ID #{{ item.id_payment_method }} · código <code>{{ item.code }}</code></p>
        {% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('metodos_pago') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('metodos_pago/nuevo')
          : admin_url('metodos_pago/' ~ item.id_payment_method ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="ek-panel">
        <h2>Datos del método</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Nombre *</span>
                <input type="text" name="name" required maxlength="64" value="{{ item.name }}">
                <small class="ek-field__hint">Lo verá el cliente en el checkout.</small>
            </label>

            <label class="ek-field">
                <span>Código (slug) *</span>
                <input type="text" name="code" required maxlength="32"
                       pattern="[a-z0-9_]+" value="{{ item.code }}"
                       {{ mode == 'edit' ? 'readonly' : '' }}>
                <small class="ek-field__hint">Solo minúsculas, números y _. No se puede cambiar tras crear.</small>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Descripción</span>
                <textarea name="description" rows="3" maxlength="1000">{{ item.description|default('') }}</textarea>
                <small class="ek-field__hint">Texto adicional visible al cliente al elegir este método.</small>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Icono / URL imagen</span>
                <input type="text" name="icon" maxlength="255" value="{{ item.icon|default('') }}"
                       placeholder="ej. /admin/assets/img/visa.svg">
            </label>

            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Visible en el checkout</span>
                </label>
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Comisión / recargo</h2>
        <p class="ek-panel__hint">Coste adicional que se aplica al pedido cuando se usa este método.</p>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Comisión porcentaje (%)</span>
                <input type="text" name="fee_percent" inputmode="decimal"
                       value="{{ item.fee_percent|default(0)|number_format(2, '.', '') }}">
                <small class="ek-field__hint">Sobre el subtotal. Ej: 2.00 = 2%.</small>
            </label>
            <label class="ek-field">
                <span>Comisión fija (€)</span>
                <input type="text" name="fee_fixed" inputmode="decimal"
                       value="{{ item.fee_fixed|default(0)|number_format(2, '.', '') }}">
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Restricciones</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Solo profesionales (B2B)</span>
                <label class="ek-switch">
                    <input type="checkbox" name="is_b2b_only" value="1" {{ item.is_b2b_only ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Visible solo a clientes con CIF/empresa</span>
                </label>
            </label>
            <label class="ek-field">
                <span>Requiere crédito autorizado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="requires_credit_limit" value="1" {{ item.requires_credit_limit ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Visible solo si el cliente tiene límite de crédito &gt; 0</span>
                </label>
                <small class="ek-field__hint">Pensado para "Pago aplazado".</small>
            </label>
        </div>
    </div>

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('metodos_pago') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear método' : 'Guardar cambios' }}
        </button>
    </div>
</form>
{% endblock %}
