{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_impuestos.twig' with {tab: 'taxes'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo impuesto' : 'Editar impuesto' }}
        </h1>
        {% if mode == 'edit' %}
            <p class="ek-page-header__subtitle">ID #{{ item.id_tax }}</p>
        {% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('impuestos') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('impuestos/nuevo')
          : admin_url('impuestos/' ~ item.id_tax ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="ek-panel">
        <h2>Datos del impuesto</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Nombre *</span>
                <input type="text" name="name" required maxlength="32" value="{{ item.name }}"
                       placeholder="IVA 21% (general)">
                <small class="ek-field__hint">Máx. 32 caracteres. Aparece en el panel y en facturas.</small>
            </label>

            <label class="ek-field">
                <span>Tasa (%) *</span>
                <input type="text" name="rate" required inputmode="decimal" maxlength="7"
                       value="{{ item.rate|default('0')|number_format(3, '.', '') }}">
                <small class="ek-field__hint">Punto como separador decimal. Hasta 3 decimales.</small>
            </label>

            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Impuesto activo</span>
                </label>
            </label>
        </div>
    </div>

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('impuestos') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear impuesto' : 'Guardar cambios' }}
        </button>
    </div>
</form>
{% endblock %}
