{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_impuestos.twig' with {tab: 'groups'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo grupo de reglas' : 'Editar grupo de reglas' }}
        </h1>
        {% if mode == 'edit' %}
            <p class="ek-page-header__subtitle">ID #{{ item.id_tax_rules_group }} · <strong>{{ item.name }}</strong></p>
        {% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('impuestos/grupos') }}">← Volver</a>
    </div>
</div>

{# ===== Datos del grupo ===== #}
<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('impuestos/grupos/nuevo')
          : admin_url('impuestos/grupos/' ~ item.id_tax_rules_group ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="ek-panel">
        <h2>Datos del grupo</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Nombre *</span>
                <input type="text" name="name" required maxlength="50" value="{{ item.name }}"
                       placeholder="IVA 21% España">
            </label>
            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Grupo activo</span>
                </label>
            </label>
        </div>
    </div>

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('impuestos/grupos') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear grupo' : 'Guardar grupo' }}
        </button>
    </div>
</form>

{% if mode == 'edit' %}
{# ===== Reglas del grupo ===== #}
<div class="ek-panel" style="margin-top:24px">
    <h2>Reglas del grupo</h2>
    <p class="ek-field__hint">
        Cada regla aplica un impuesto a un país (opcionalmente con estado o rango de CP).
        Si dejas <span class="mono">0</span> en CP, la regla cubre todo el país.
    </p>

    <div class="ek-table-wrap">
        <table class="ek-table">
            <thead>
                <tr>
                    <th style="width:60px">ID</th>
                    <th>País</th>
                    <th style="width:160px">CP desde — hasta</th>
                    <th>Impuesto</th>
                    <th style="width:140px">Comportamiento</th>
                    <th>Descripción</th>
                    <th style="width:80px; text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for r in rules %}
                <tr>
                    <td class="mono">{{ r.id_tax_rule }}</td>
                    <td>{{ r.country_name|default('País #' ~ r.id_country) }}</td>
                    <td class="mono">{{ r.zipcode_from }} — {{ r.zipcode_to }}</td>
                    <td>{{ r.tax_name|default('—') }} ({{ r.tax_rate|default(0)|number_format(3, ',', '.') }} %)</td>
                    <td>{{ behaviors[r.behavior]|default('—') }}</td>
                    <td style="color:var(--ek-ink-3); font-size:12px">{{ r.description|default('—') }}</td>
                    <td style="text-align:right">
                        <form method="post"
                              action="{{ admin_url('impuestos/grupos/' ~ item.id_tax_rules_group ~ '/reglas/' ~ r.id_tax_rule ~ '/eliminar') }}"
                              style="display:inline"
                              onsubmit="return confirm('¿Eliminar esta regla?');">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="ek-table__empty">Aún no hay reglas. Añade la primera abajo.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ===== Añadir regla ===== #}
    <form method="post" class="ek-form" style="margin-top:20px"
          action="{{ admin_url('impuestos/grupos/' ~ item.id_tax_rules_group ~ '/reglas/nueva') }}">
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <h3 style="margin:0 0 12px 0">Añadir regla</h3>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>País *</span>
                <select name="id_country" required>
                    <option value="0">— Selecciona país —</option>
                    {% for c in countries %}
                        <option value="{{ c.id_country }}" {{ c.id_country == 6 ? 'selected' : '' }}>{{ c.name }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Impuesto *</span>
                <select name="id_tax" required>
                    <option value="0">— Selecciona impuesto —</option>
                    {% for t in taxes %}
                        <option value="{{ t.id_tax }}">{{ t.name }} ({{ t.rate|number_format(3, ',', '.') }} %)</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>CP desde</span>
                <input type="text" name="zipcode_from" maxlength="12" value="0">
            </label>
            <label class="ek-field">
                <span>CP hasta</span>
                <input type="text" name="zipcode_to" maxlength="12" value="0">
            </label>

            <label class="ek-field">
                <span>Comportamiento</span>
                <select name="behavior">
                    {% for k, label in behaviors %}
                        <option value="{{ k }}" {{ k == 0 ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Descripción (opcional)</span>
                <input type="text" name="description" maxlength="100" placeholder="Ej. Península y Baleares">
            </label>
        </div>
        <div class="ek-form__actions">
            <button type="submit" class="ek-btn ek-btn--primary">+ Añadir regla</button>
        </div>
    </form>
</div>
{% endif %}
{% endblock %}
