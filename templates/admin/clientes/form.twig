{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_clientes.twig' with {tab: 'clientes'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo cliente' : 'Editar cliente' }}
        </h1>
        {% if mode == 'edit' %}
            <p class="ek-page-header__subtitle">ID #{{ item.id_customer }} · alta {{ item.date_add|date('d/m/Y') }}</p>
        {% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('clientes') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('clientes/nuevo')
          : admin_url('clientes/' ~ item.id_customer ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="ek-panel">
        <h2>Datos personales</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Tratamiento</span>
                <select name="id_gender">
                    {% for k, label in genders %}
                        <option value="{{ k }}" {{ item.id_gender == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Cliente activo</span>
                </label>
            </label>

            <label class="ek-field">
                <span>Nombre *</span>
                <input type="text" name="firstname" required value="{{ item.firstname }}">
            </label>

            <label class="ek-field">
                <span>Apellidos *</span>
                <input type="text" name="lastname" required value="{{ item.lastname }}">
            </label>

            <label class="ek-field ek-field--wide">
                <span>Email *</span>
                <input type="email" name="email" required value="{{ item.email }}">
            </label>

            <label class="ek-field">
                <span>{{ mode == 'create' ? 'Contraseña *' : 'Nueva contraseña' }}</span>
                <input type="password" name="password"
                       {% if mode == 'create' %}required{% endif %}
                       minlength="8" autocomplete="new-password"
                       placeholder="{{ mode == 'edit' ? 'Dejar vacío para no cambiar' : 'Mín. 8 caracteres' }}">
            </label>

            <label class="ek-field">
                <span>Fecha de nacimiento</span>
                <input type="date" name="birthday" value="{{ item.birthday|default('') }}">
            </label>

            <label class="ek-field">
                <span>Web</span>
                <input type="url" name="website" value="{{ item.website|default('') }}" placeholder="https://...">
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Datos profesionales (B2B)</h2>
        <p class="ek-panel__hint">
            Si rellenas <em>empresa</em> o <em>CIF</em> el cliente se trata como profesional.
            Los profesionales verán precios sin IVA en la tienda.
        </p>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Razón social</span>
                <input type="text" name="company" maxlength="64" value="{{ item.company|default('') }}">
            </label>
            <label class="ek-field">
                <span>CIF / NIF</span>
                <input type="text" name="siret" maxlength="14" value="{{ item.siret|default('') }}">
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Pago aplazado</h2>
        <p class="ek-panel__hint">
            Habilita pago aplazado para este cliente. Si <strong>Crédito autorizado &gt; 0</strong>
            podrá ver la opción de pago aplazado en el checkout.
        </p>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Crédito autorizado (€)</span>
                <input type="text" name="outstanding_allow_amount" inputmode="decimal"
                       value="{{ item.outstanding_allow_amount|default(0)|number_format(2, '.', '') }}">
                <small class="ek-field__hint">0 = pago aplazado deshabilitado.</small>
            </label>
            <label class="ek-field">
                <span>Días de vencimiento</span>
                <input type="number" name="max_payment_days" min="0" value="{{ item.max_payment_days|default(0) }}">
                <small class="ek-field__hint">30, 60, 90 días típicamente.</small>
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Comunicación</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Newsletter</span>
                <label class="ek-switch">
                    <input type="checkbox" name="newsletter" value="1" {{ item.newsletter ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Suscrito a la newsletter</span>
                </label>
            </label>
            <label class="ek-field">
                <span>Optin marketing</span>
                <label class="ek-switch">
                    <input type="checkbox" name="optin" value="1" {{ item.optin ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Acepta comunicaciones comerciales</span>
                </label>
            </label>
            <label class="ek-field ek-field--wide">
                <span>Notas internas</span>
                <textarea name="note" rows="3">{{ item.note|default('') }}</textarea>
            </label>
        </div>
    </div>

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('clientes') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear cliente' : 'Guardar cambios' }}
        </button>
    </div>
</form>

{% if mode == 'edit' %}
<div class="ek-panel" style="margin-top:16px">
    <h2>Direcciones del cliente</h2>
    {% if addresses|length > 0 %}
        <table class="ek-table" style="margin-top:6px">
            <thead>
                <tr>
                    <th style="width:60px">ID</th>
                    <th>Alias</th>
                    <th>Destinatario</th>
                    <th>Localidad</th>
                    <th style="width:120px; text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for a in addresses %}
                <tr>
                    <td class="mono">{{ a.id_address }}</td>
                    <td><strong>{{ a.alias }}</strong></td>
                    <td>{{ a.firstname }} {{ a.lastname }}</td>
                    <td style="color: var(--ek-ink-3); font-size:12px">{{ a.postcode }} {{ a.city }}</td>
                    <td style="text-align:right">
                        <a class="ek-action" href="{{ admin_url('direcciones/' ~ a.id_address ~ '/editar') }}">Editar</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p style="color: var(--ek-ink-3); margin: 6px 0 14px">Este cliente aún no tiene direcciones.</p>
    {% endif %}
    <a class="ek-btn ek-btn--ghost" href="{{ admin_url('direcciones/nuevo') }}?id_customer={{ item.id_customer }}">+ Añadir dirección</a>
</div>
{% endif %}
{% endblock %}
