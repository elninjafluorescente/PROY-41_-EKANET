<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title|default('Panel') }} · {{ app.name }}</title>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
</head>
<body class="ek ek-admin">

<aside class="ek-sidebar">
    <div class="ek-sidebar__brand">
        <img src="{{ asset('img/logo-ekanet.png') }}" alt="Ekanet" class="ek-sidebar__logo">
        <span class="ek-sidebar__tag mono">ADMIN</span>
    </div>

    <nav class="ek-sidebar__nav">
        <a href="{{ admin_url('dashboard') }}" class="{{ active == 'dashboard' ? 'is-active' : '' }}">
            <span class="ek-node"></span> Dashboard
        </a>

        <details class="ek-sidebar__section" {% if active in ['pedidos'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Pedidos</summary>
            <a href="{{ admin_url('pedidos') }}" class="{{ active == 'pedidos' ? 'is-active' : '' }}">Pedidos y facturas</a>
        </details>

        <details class="ek-sidebar__section" {% if active in ['productos','categorias','marcas_proveedores','descuentos','stock','atributos_caracteristicas'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Catálogo</summary>
            <a href="{{ admin_url('productos') }}" class="{{ active == 'productos' ? 'is-active' : '' }}">Productos</a>
            <a href="{{ admin_url('categorias') }}" class="{{ active == 'categorias' ? 'is-active' : '' }}">Categorías</a>
            <a href="{{ admin_url('marcas') }}" class="{{ active == 'marcas_proveedores' ? 'is-active' : '' }}">Marcas y proveedores</a>
            <a href="{{ admin_url('cupones') }}" class="{{ active == 'descuentos' ? 'is-active' : '' }}">Descuentos</a>
            <a href="{{ admin_url('stock') }}" class="{{ active == 'stock' ? 'is-active' : '' }}">Stock</a>
            <a href="{{ admin_url('atributos') }}" class="{{ active == 'atributos_caracteristicas' ? 'is-active' : '' }}">Atributos y características</a>
        </details>

        <details class="ek-sidebar__section" {% if active in ['clientes','direcciones'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Clientes</summary>
            <a href="{{ admin_url('clientes') }}" class="{{ active == 'clientes' ? 'is-active' : '' }}">Clientes</a>
            <a href="{{ admin_url('direcciones') }}" class="{{ active == 'direcciones' ? 'is-active' : '' }}">Direcciones</a>
        </details>

        <details class="ek-sidebar__section" {% if active in ['transportistas'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Transporte</summary>
            <a href="{{ admin_url('transportistas') }}" class="{{ active == 'transportistas' ? 'is-active' : '' }}">Transportistas</a>
        </details>

        <details class="ek-sidebar__section" {% if active in ['metodos_pago'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Pago</summary>
            <a href="{{ admin_url('metodos_pago') }}" class="{{ active == 'metodos_pago' ? 'is-active' : '' }}">Métodos de pago</a>
        </details>

        <details class="ek-sidebar__section" {% if active in ['marketing','blog'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Marketing</summary>
            <a href="{{ admin_url('pixeles') }}" class="{{ active == 'marketing' ? 'is-active' : '' }}">Píxeles y banners</a>
            <a href="{{ admin_url('blog') }}" class="{{ active == 'blog' ? 'is-active' : '' }}">Blog</a>
        </details>

        <details class="ek-sidebar__section" {% if active in ['usuarios','roles','configuracion'] %}open{% endif %}>
            <summary class="ek-sidebar__group">Administración</summary>
            <a href="{{ admin_url('usuarios') }}" class="{{ active == 'usuarios' ? 'is-active' : '' }}">Usuarios</a>
            <a href="{{ admin_url('configuracion') }}" class="{{ active == 'configuracion' ? 'is-active' : '' }}">Configuración</a>
        </details>
    </nav>
</aside>

<main class="ek-main">
    <header class="ek-topbar">
        <div class="ek-topbar__title">{{ page_title|default('Panel de administración') }}</div>
        <div class="ek-topbar__actions">
            {% set u = current_user() %}
            {% if u %}
                <span class="mono">{{ u.email }}</span>
                <a class="ek-btn ek-btn--ghost" href="{{ admin_url('logout') }}">Salir</a>
            {% endif %}
        </div>
    </header>

    {% set _flash_ok = flash('success') %}
    {% if _flash_ok %}<div class="ek-alert ek-alert--ok">{{ _flash_ok }}</div>{% endif %}
    {% set _flash_err = flash('error') %}
    {% if _flash_err %}<div class="ek-alert ek-alert--err">{{ _flash_err }}</div>{% endif %}

    <div class="ek-content">
        {% block content %}{% endblock %}
    </div>
</main>

<script src="{{ asset('js/admin.js') }}"></script>
</body>
</html>
