<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Restablecer contraseña · {{ app.name }}</title>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
</head>
<body class="ek ek-login">
    <div class="ek-login__card">
        <div class="ek-login__brand">
            <img src="{{ asset('img/logo-ekanet.png') }}" alt="Ekanet" class="ek-login__logo">
        </div>

        <h1 class="ek-login__title">Nueva contraseña</h1>
        <p style="color: var(--ek-ink-3); font-size: 13px; margin: -10px 0 18px">
            Cuenta: <strong class="mono">{{ email }}</strong>
        </p>

        {% if error %}<div class="ek-alert ek-alert--err">{{ error }}</div>{% endif %}

        <form method="post" action="{{ admin_url('recuperar-password/' ~ token) }}" autocomplete="off">
            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
            <label class="ek-field">
                <span>Nueva contraseña</span>
                <input type="password" name="password" required minlength="8" autofocus autocomplete="new-password">
            </label>
            <label class="ek-field">
                <span>Repite la contraseña</span>
                <input type="password" name="password_confirm" required minlength="8" autocomplete="new-password">
            </label>
            <button type="submit" class="ek-btn ek-btn--primary ek-btn--block">Cambiar contraseña</button>
        </form>
    </div>
</body>
</html>
