<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Recuperar contraseña · {{ app.name }}</title>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
</head>
<body class="ek ek-login">
    <div class="ek-login__card">
        <div class="ek-login__brand">
            <img src="{{ asset('img/logo-ekanet.png') }}" alt="Ekanet" class="ek-login__logo">
        </div>

        <h1 class="ek-login__title">Recuperar contraseña</h1>
        <p style="color: var(--ek-ink-3); font-size: 13px; margin: -10px 0 18px">
            Introduce tu email y te enviaremos un enlace para restablecer tu contraseña.
        </p>

        {% if error %}<div class="ek-alert ek-alert--err">{{ error }}</div>{% endif %}

        <form method="post" action="{{ admin_url('recuperar-password') }}" autocomplete="off">
            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
            <label class="ek-field">
                <span>Email</span>
                <input type="email" name="email" required autofocus>
            </label>
            <button type="submit" class="ek-btn ek-btn--primary ek-btn--block">Enviar enlace</button>
        </form>

        <p style="text-align:center; margin-top: 18px; font-size: 13px;">
            <a href="{{ admin_url('login') }}" style="color: var(--ek-blue-deep); text-decoration: none">← Volver al login</a>
        </p>
    </div>
</body>
</html>
