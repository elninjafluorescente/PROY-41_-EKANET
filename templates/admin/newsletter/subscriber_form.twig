{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_newsletter.twig' with {tab: 'subscribers'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">{{ mode == 'create' ? 'Nuevo suscriptor' : 'Editar suscriptor' }}</h1>
        {% if mode == 'edit' %}<p class="ek-page-header__subtitle">ID #{{ item.id }}</p>{% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('newsletter/suscriptores') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('newsletter/suscriptores/nuevo')
          : admin_url('newsletter/suscriptores/' ~ item.id ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
    <div class="ek-panel">
        <h2>Datos del suscriptor</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Email *</span>
                <input type="email" name="email" required maxlength="255" value="{{ item.email }}" class="mono">
            </label>
            <label class="ek-field ek-field--wide">
                <span>Nombre</span>
                <input type="text" name="name" maxlength="128" value="{{ item.name|default('') }}">
            </label>
            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Suscripción activa</span>
                </label>
            </label>
        </div>
    </div>
    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('newsletter/suscriptores') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">{{ mode == 'create' ? 'Añadir' : 'Guardar' }}</button>
    </div>
</form>
{% endblock %}
