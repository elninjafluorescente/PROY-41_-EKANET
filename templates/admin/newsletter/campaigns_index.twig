{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_newsletter.twig' with {tab: 'campaigns'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Campañas</h1>
        <p class="ek-page-header__subtitle">{{ total }} campaña{{ total == 1 ? '' : 's' }} en total.</p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('newsletter/campanas/nueva') }}">+ Nueva campaña</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Asunto</th>
                <th style="width:110px">Estado</th>
                <th style="width:90px">Target</th>
                <th style="width:140px">Envío</th>
                <th style="width:140px">Fecha</th>
                <th style="width:90px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for c in campaigns %}
            <tr>
                <td class="mono">{{ c.id_campaign }}</td>
                <td><a href="{{ admin_url('newsletter/campanas/' ~ c.id_campaign ~ '/editar') }}"><strong>{{ c.subject }}</strong></a></td>
                <td><span class="ek-badge ek-badge--{{ badges[c.status] }}">{{ statuses[c.status] }}</span></td>
                <td style="font-size:12px; color:var(--ek-ink-3)">{{ c.target }}</td>
                <td class="mono" style="font-size:12px">
                    {% if c.recipients_count > 0 %}
                        {{ c.sent_count }}/{{ c.recipients_count }}
                        {% if c.failed_count > 0 %}<span style="color:#c62828"> · {{ c.failed_count }} fallos</span>{% endif %}
                    {% else %}—{% endif %}
                </td>
                <td class="mono" style="font-size:12px">{{ c.date_finished|default(c.date_add)|slice(0,16) }}</td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('newsletter/campanas/' ~ c.id_campaign ~ '/editar') }}">Abrir</a>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="7" class="ek-table__empty">No hay campañas.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if pages > 1 %}
<div style="margin-top:12px; display:flex; gap:8px; justify-content:center">
    {% for n in 1..pages %}
        {% if n == page %}<strong class="mono">{{ n }}</strong>
        {% else %}<a class="mono" href="{{ admin_url('newsletter/campanas') }}?p={{ n }}">{{ n }}</a>{% endif %}
    {% endfor %}
</div>
{% endif %}
{% endblock %}
