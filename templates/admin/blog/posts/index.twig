{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_blog.twig' with {tab: 'posts'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Artículos del blog</h1>
        <p class="ek-page-header__subtitle">Total: <strong>{{ total }}</strong> artículo{{ total == 1 ? '' : 's' }}.</p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('blog/nuevo') }}">+ Nuevo artículo</a>
    </div>
</div>

<form method="get" action="{{ admin_url('blog') }}" class="ek-search-bar">
    <input type="search" name="q" value="{{ search }}" placeholder="Buscar por título, slug o extracto…">
    <select name="status" onchange="this.form.submit()">
        <option value="">Todos los estados</option>
        {% for k, label in statuses %}
            <option value="{{ k }}" {{ k == status_filter ? 'selected' : '' }}>{{ label }}</option>
        {% endfor %}
    </select>
    <select name="cat" onchange="this.form.submit()">
        <option value="0">Todas las categorías</option>
        {% for c in categories %}
            <option value="{{ c.id_blog_category }}" {{ c.id_blog_category == cat_filter ? 'selected' : '' }}>{{ c.name }}</option>
        {% endfor %}
    </select>
    <button type="submit" class="ek-btn ek-btn--ghost">Filtrar</button>
    {% if search or status_filter or cat_filter %}<a class="ek-btn ek-btn--ghost" href="{{ admin_url('blog') }}">Limpiar</a>{% endif %}
</form>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Título</th>
                <th>Categoría</th>
                <th>Autor</th>
                <th style="width:90px">Estado</th>
                <th style="width:110px">Publicación</th>
                <th style="width:80px; text-align:right">Lecturas</th>
                <th style="width:140px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for p in posts %}
            <tr>
                <td class="mono">{{ p.id_post }}</td>
                <td>
                    <strong>{{ p.title }}</strong>
                    {% if p.pending_comments > 0 %}
                        <span class="ek-pill ek-pill--gold">{{ p.pending_comments }} comentario{{ p.pending_comments > 1 ? 's' : '' }} pendiente{{ p.pending_comments > 1 ? 's' : '' }}</span>
                    {% endif %}
                    <br><span class="mono" style="font-size:11px; color:var(--ek-ink-3)">/blog/{{ p.slug }}</span>
                </td>
                <td style="font-size:12px">{{ p.category_name|default('—') }}</td>
                <td style="font-size:12px">{{ p.author_firstname|default('—') }} {{ p.author_lastname|default('') }}</td>
                <td>
                    {% if p.status == 'published' %}
                        <span class="ek-badge ek-badge--ok">Publicado</span>
                    {% elseif p.status == 'scheduled' %}
                        <span class="ek-badge" style="background: var(--ek-blue-soft); border-color: var(--ek-blue); color: var(--ek-blue-deep)">Programado</span>
                    {% else %}
                        <span class="ek-badge ek-badge--muted">Borrador</span>
                    {% endif %}
                </td>
                <td style="font-size:12px; color:var(--ek-ink-3)">
                    {{ p.published_at ? p.published_at|date('d/m/Y') : '—' }}
                </td>
                <td class="mono" style="text-align:right">{{ p.views }}</td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('blog/' ~ p.id_post ~ '/editar') }}">Editar</a>
                    <form method="post" action="{{ admin_url('blog/' ~ p.id_post ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar el artículo \'{{ p.title }}\' y sus comentarios?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="8" class="ek-table__empty">No hay artículos todavía. Crea el primero.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if pages > 1 %}
<nav class="ek-pagination">
    {% for i in 1..pages %}
        <a href="{{ admin_url('blog') }}?p={{ i }}{% if search %}&q={{ search|url_encode }}{% endif %}{% if status_filter %}&status={{ status_filter }}{% endif %}{% if cat_filter %}&cat={{ cat_filter }}{% endif %}"
           class="ek-pagination__page {{ i == page ? 'is-active' : '' }}">{{ i }}</a>
    {% endfor %}
</nav>
{% endif %}
{% endblock %}
