{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_atributos_caracteristicas.twig' with {tab: 'atributos'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Atributos</h1>
        <p class="ek-page-header__subtitle">
            Grupos de <strong>variantes</strong> que el cliente elige (color, talla, longitud…).
            Cada grupo tiene sus valores.
        </p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('atributos/nuevo') }}">+ Nuevo grupo</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Nombre</th>
                <th>Nombre público</th>
                <th style="width:110px">Tipo</th>
                <th style="width:80px">Valores</th>
                <th style="width:160px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for g in groups %}
            <tr>
                <td class="mono">{{ g.id_attribute_group }}</td>
                <td><strong>{{ g.name }}</strong></td>
                <td style="color: var(--ek-ink-3)">{{ g.public_name }}</td>
                <td>
                    <span class="ek-pill ek-pill--blue">{{ types[g.group_type]|default(g.group_type) }}</span>
                </td>
                <td class="mono">{{ g.value_count }}</td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('atributos/' ~ g.id_attribute_group ~ '/editar') }}">Editar</a>
                    <form method="post" action="{{ admin_url('atributos/' ~ g.id_attribute_group ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar el grupo \'{{ g.name }}\' y todos sus valores?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6" class="ek-table__empty">No hay grupos de atributos todavía.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
