{% extends 'admin/_layout.twig' %}

{% block content %}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Productos</h1>
        <p class="ek-page-header__subtitle">
            Catálogo completo. Total: <strong>{{ total }}</strong> producto{{ total == 1 ? '' : 's' }}.
        </p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('productos/importar') }}">↑ Importar CSV</a>
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('productos/nuevo') }}">+ Nuevo producto</a>
    </div>
</div>

<form method="get" action="{{ admin_url('productos') }}" class="ek-search-bar">
    <input type="search" name="q" value="{{ search }}" placeholder="Buscar por nombre o referencia…">
    <button type="submit" class="ek-btn ek-btn--ghost">Buscar</button>
    {% if search %}
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('productos') }}">Limpiar</a>
    {% endif %}
</form>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th style="width:110px">Referencia</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Marca</th>
                <th style="width:90px; text-align:right">Precio</th>
                <th style="width:70px; text-align:right">Stock</th>
                <th style="width:80px">Estado</th>
                <th style="width:140px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for p in products %}
            <tr>
                <td class="mono">{{ p.id_product }}</td>
                <td class="mono" style="font-size:12px">{{ p.reference|default('—') }}</td>
                <td><strong>{{ p.name }}</strong></td>
                <td style="color: var(--ek-ink-3); font-size:12px">{{ p.category_name|default('—') }}</td>
                <td style="color: var(--ek-ink-3); font-size:12px">{{ p.manufacturer_name|default('—') }}</td>
                <td class="mono" style="text-align:right">{{ p.price|number_format(2, ',', '.') }} €</td>
                <td class="mono" style="text-align:right">{{ p.stock }}</td>
                <td>
                    {% if p.active %}
                        <span class="ek-badge ek-badge--ok">Activo</span>
                    {% else %}
                        <span class="ek-badge ek-badge--muted">Borrador</span>
                    {% endif %}
                </td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('productos/' ~ p.id_product ~ '/editar') }}">Editar</a>
                    <form method="post" action="{{ admin_url('productos/' ~ p.id_product ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar el producto \'{{ p.name }}\'?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="9" class="ek-table__empty">
                {{ search ? 'No hay productos que coincidan con "' ~ search ~ '".' : 'No hay productos todavía.' }}
            </td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if pages > 1 %}
<nav class="ek-pagination">
    {% for i in 1..pages %}
        <a href="{{ admin_url('productos') }}?p={{ i }}{% if search %}&q={{ search|url_encode }}{% endif %}"
           class="ek-pagination__page {{ i == page ? 'is-active' : '' }}">{{ i }}</a>
    {% endfor %}
</nav>
{% endif %}
{% endblock %}
