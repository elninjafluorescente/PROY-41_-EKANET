{% extends 'admin/_layout.twig' %}

{% block content %}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">
            {{ mode == 'create' ? 'Nuevo producto' : 'Editar producto' }}
        </h1>
        {% if mode == 'edit' %}
            <p class="ek-page-header__subtitle">
                ID #{{ item.id_product }} · ref. {{ item.reference|default('—') }}
            </p>
        {% endif %}
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('productos') }}">← Volver</a>
    </div>
</div>

<form method="post" class="ek-form"
      action="{{ mode == 'create'
          ? admin_url('productos/nuevo')
          : admin_url('productos/' ~ item.id_product ~ '/editar') }}">
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    {# ============ Básico ============ #}
    <div class="ek-panel">
        <h2>Información básica</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Nombre *</span>
                <input type="text" name="name" required maxlength="128"
                       value="{{ item.name }}" id="ek-prod-name">
            </label>

            <label class="ek-field">
                <span>Referencia (SKU)</span>
                <input type="text" name="reference" maxlength="64" value="{{ item.reference }}">
                <small class="ek-field__hint">Identificador interno único.</small>
            </label>

            <label class="ek-field">
                <span>Ref. proveedor</span>
                <input type="text" name="supplier_reference" maxlength="64" value="{{ item.supplier_reference }}">
            </label>

            <label class="ek-field">
                <span>EAN-13</span>
                <input type="text" name="ean13" maxlength="13" value="{{ item.ean13 }}">
            </label>

            <label class="ek-field">
                <span>MPN</span>
                <input type="text" name="mpn" maxlength="40" value="{{ item.mpn }}">
                <small class="ek-field__hint">Part number del fabricante.</small>
            </label>

            <label class="ek-field">
                <span>Estado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Producto visible en la tienda</span>
                </label>
            </label>

            <label class="ek-field">
                <span>Destacado</span>
                <label class="ek-switch">
                    <input type="checkbox" name="is_featured" value="1" {{ item.is_featured|default(0) ? 'checked' : '' }}>
                    <span class="ek-switch__track"><span class="ek-switch__thumb"></span></span>
                    <span class="ek-switch__label">Mostrar en home</span>
                </label>
                <small class="ek-field__hint">Aparecerá en el bloque de destacados. <a href="{{ admin_url('destacados') }}">Gestionar</a>.</small>
            </label>

            <label class="ek-field">
                <span>Tipo</span>
                <select name="product_type">
                    {% for k, label in product_types %}
                        <option value="{{ k }}" {{ item.product_type == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>
        </div>
    </div>

    {# ============ Asociaciones ============ #}
    <div class="ek-panel" style="margin-top:16px">
        <h2>Asociaciones</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Categoría principal *</span>
                <select name="id_category_default" required>
                    {% for c in categories %}
                        {% if not c.is_root_category %}
                        <option value="{{ c.id_category }}"
                                {{ c.id_category == item.id_category_default ? 'selected' : '' }}>
                            {% if c.level_depth > 1 %}{% for _ in 2..c.level_depth %}— {% endfor %}{% endif %}{{ c.name }}
                        </option>
                        {% endif %}
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Marca</span>
                <select name="id_manufacturer">
                    <option value="0">— Sin marca —</option>
                    {% for m in manufacturers %}
                        <option value="{{ m.id_manufacturer }}"
                                {{ m.id_manufacturer == item.id_manufacturer ? 'selected' : '' }}>
                            {{ m.name }}
                        </option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Proveedor</span>
                <select name="id_supplier">
                    <option value="0">— Sin proveedor —</option>
                    {% for s in suppliers %}
                        <option value="{{ s.id_supplier }}"
                                {{ s.id_supplier == item.id_supplier ? 'selected' : '' }}>
                            {{ s.name }}
                        </option>
                    {% endfor %}
                </select>
            </label>
        </div>
    </div>

    {# ============ Precio y stock ============ #}
    <div class="ek-panel" style="margin-top:16px">
        <h2>Precio y stock</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Precio sin IVA *</span>
                <input type="text" name="price" required inputmode="decimal"
                       value="{{ item.price|number_format(2, '.', '') }}">
                <small class="ek-field__hint">Usa punto como separador decimal.</small>
            </label>

            <label class="ek-field">
                <span>Precio mayorista</span>
                <input type="text" name="wholesale_price" inputmode="decimal"
                       value="{{ item.wholesale_price|default(0)|number_format(2, '.', '') }}">
                <small class="ek-field__hint">Precio de coste. Informativo.</small>
            </label>

            <label class="ek-field">
                <span>Grupo de impuestos</span>
                <select name="id_tax_rules_group">
                    <option value="0">— Sin impuesto —</option>
                    {% for g in tax_rules_groups %}
                        <option value="{{ g.id_tax_rules_group }}"
                                {{ g.id_tax_rules_group == item.id_tax_rules_group|default(0) ? 'selected' : '' }}>
                            {{ g.name }}{{ not g.active ? ' (inactivo)' : '' }}
                        </option>
                    {% endfor %}
                </select>
                <small class="ek-field__hint">Define qué IVA se aplica según país de envío. <a href="{{ admin_url('impuestos/grupos') }}">Gestionar grupos</a>.</small>
            </label>

            <label class="ek-field">
                <span>Stock disponible</span>
                <input type="number" name="stock" min="0" value="{{ item.stock|default(0) }}">
            </label>

            <label class="ek-field">
                <span>Cantidad mínima de compra</span>
                <input type="number" name="minimal_quantity" min="1" value="{{ item.minimal_quantity|default(1) }}">
            </label>

            <label class="ek-field">
                <span>Visibilidad</span>
                <select name="visibility">
                    {% for k, label in visibilities %}
                        <option value="{{ k }}" {{ item.visibility == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="ek-field">
                <span>Estado del producto</span>
                <select name="condition">
                    {% for k, label in conditions %}
                        <option value="{{ k }}" {{ item.condition == k ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>
        </div>
    </div>

    {# ============ Descripciones ============ #}
    <div class="ek-panel" style="margin-top:16px">
        <h2>Descripciones</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Descripción corta</span>
                <textarea name="description_short" rows="3" maxlength="800" class="ek-rich ek-rich--compact">{{ item.description_short }}</textarea>
                <small class="ek-field__hint">Aparece en listados y en la parte superior de la ficha.</small>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Descripción completa</span>
                <textarea name="description" rows="10" class="ek-rich">{{ item.description }}</textarea>
            </label>
        </div>
    </div>

    {# ============ SEO y dimensiones ============ #}
    <div class="ek-panel" style="margin-top:16px">
        <h2>SEO</h2>
        <div class="ek-form__grid">
            <label class="ek-field ek-field--wide">
                <span>Slug (link_rewrite)</span>
                <input type="text" name="link_rewrite" maxlength="128"
                       value="{{ item.link_rewrite }}"
                       placeholder="se generará desde el nombre"
                       id="ek-prod-slug">
            </label>

            <label class="ek-field ek-field--wide">
                <span>Meta título</span>
                <input type="text" name="meta_title" maxlength="255" value="{{ item.meta_title }}">
            </label>

            <label class="ek-field ek-field--wide">
                <span>Meta descripción</span>
                <textarea name="meta_description" rows="2" maxlength="512">{{ item.meta_description }}</textarea>
            </label>

            <label class="ek-field ek-field--wide">
                <span>Meta keywords</span>
                <input type="text" name="meta_keywords" maxlength="255" value="{{ item.meta_keywords }}">
            </label>
        </div>
    </div>

    <div class="ek-panel" style="margin-top:16px">
        <h2>Dimensiones físicas</h2>
        <div class="ek-form__grid">
            <label class="ek-field">
                <span>Peso (kg)</span>
                <input type="text" name="weight" inputmode="decimal" value="{{ item.weight|default(0) }}">
            </label>
            <label class="ek-field">
                <span>Ancho (cm)</span>
                <input type="text" name="width" inputmode="decimal" value="{{ item.width|default(0) }}">
            </label>
            <label class="ek-field">
                <span>Alto (cm)</span>
                <input type="text" name="height" inputmode="decimal" value="{{ item.height|default(0) }}">
            </label>
            <label class="ek-field">
                <span>Profundidad (cm)</span>
                <input type="text" name="depth" inputmode="decimal" value="{{ item.depth|default(0) }}">
            </label>
        </div>
    </div>

    <div class="ek-form__actions">
        <a class="ek-btn ek-btn--ghost" href="{{ admin_url('productos') }}">Cancelar</a>
        <button type="submit" class="ek-btn ek-btn--primary">
            {{ mode == 'create' ? 'Crear producto' : 'Guardar cambios' }}
        </button>
    </div>
</form>

{% if mode == 'edit' %}
<div class="ek-panel" id="imagenes" style="margin-top:16px">
    <h2>Imágenes</h2>
    <p class="ek-panel__hint">
        Sube imágenes JPG, PNG o WebP (máx. 8 MB). La portada (★) se muestra en listados.
    </p>

    {% if images|length > 0 %}
        <div class="ek-img-grid">
            {% for img in images %}
                <div class="ek-img-card">
                    <div class="ek-img-card__preview">
                        {% if img.url %}
                            <img src="{{ img.thumb_url|default(img.url) }}" alt="{{ img.legend|default('') }}" loading="lazy">
                        {% else %}
                            <span class="ek-placeholder" style="display:flex; width:100%; height:100%; align-items:center; justify-content:center">SIN IMG</span>
                        {% endif %}
                        {% if img.cover %}<span class="ek-img-card__cover">★ Portada</span>{% endif %}
                    </div>
                    <div class="ek-img-card__id mono">#{{ img.id_image }}</div>

                    <form method="post"
                          action="{{ admin_url('productos/' ~ item.id_product ~ '/imagenes/' ~ img.id_image ~ '/legend') }}"
                          class="ek-img-card__legend">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="text" name="legend" value="{{ img.legend|default('') }}"
                               maxlength="128" placeholder="Texto alternativo (alt)">
                        <button type="submit" class="ek-action">Guardar alt</button>
                    </form>

                    <div class="ek-img-card__actions">
                        {% if not img.cover %}
                            <form method="post" style="display:inline"
                                  action="{{ admin_url('productos/' ~ item.id_product ~ '/imagenes/' ~ img.id_image ~ '/portada') }}">
                                <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                                <button type="submit" class="ek-action" title="Marcar como portada">☆</button>
                            </form>
                        {% endif %}
                        <form method="post" style="display:inline"
                              action="{{ admin_url('productos/' ~ item.id_product ~ '/imagenes/' ~ img.id_image ~ '/mover/up') }}">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <button type="submit" class="ek-action" title="Subir">↑</button>
                        </form>
                        <form method="post" style="display:inline"
                              action="{{ admin_url('productos/' ~ item.id_product ~ '/imagenes/' ~ img.id_image ~ '/mover/down') }}">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <button type="submit" class="ek-action" title="Bajar">↓</button>
                        </form>
                        <form method="post" style="display:inline"
                              action="{{ admin_url('productos/' ~ item.id_product ~ '/imagenes/' ~ img.id_image ~ '/eliminar') }}"
                              onsubmit="return confirm('¿Eliminar esta imagen?');">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p style="color: var(--ek-ink-3); margin: 8px 0 14px">Aún no hay imágenes para este producto.</p>
    {% endif %}

    <h3 style="font-size:13px; margin-top:18px; padding-top:14px; border-top:1px solid var(--ek-line)">+ Subir imagen</h3>
    <form method="post" enctype="multipart/form-data"
          action="{{ admin_url('productos/' ~ item.id_product ~ '/imagenes/subir') }}"
          style="display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap">
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <input type="hidden" name="MAX_FILE_SIZE" value="8388608">
        <label class="ek-field" style="margin:0; flex:0 0 auto">
            <span>Archivo</span>
            <input type="file" name="image" accept="image/jpeg,image/png,image/webp" required>
        </label>
        <label class="ek-field" style="margin:0; flex:1; min-width:200px">
            <span>Texto alternativo (opcional)</span>
            <input type="text" name="legend" maxlength="128" placeholder="ej. Vista frontal armario rack">
        </label>
        <button type="submit" class="ek-btn ek-btn--primary">Subir imagen</button>
    </form>
</div>

<div class="ek-panel" id="combinaciones" style="margin-top:16px">
    <h2>Combinaciones (variantes)</h2>
    <p class="ek-panel__hint">
        Si el producto tiene variantes (color, talla, longitud…) crea aquí cada combinación.
        Cada combinación tiene su propio stock, referencia y precio.
    </p>

    {% if combinations|length > 0 %}
        <table class="ek-table" style="margin-top:8px">
            <thead>
                <tr>
                    <th style="width:50px">Default</th>
                    <th>Combinación</th>
                    <th style="width:140px">Referencia</th>
                    <th style="width:110px; text-align:right">Impacto precio</th>
                    <th style="width:80px; text-align:right">Stock</th>
                    <th style="width:160px; text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for c in combinations %}
                <tr>
                    <td style="text-align:center">
                        {% if c.default_on %}
                            <span class="ek-pill ek-pill--gold">★</span>
                        {% else %}
                            <form method="post" style="display:inline"
                                  action="{{ admin_url('productos/' ~ item.id_product ~ '/combinaciones/' ~ c.id_product_attribute ~ '/default') }}">
                                <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                                <button type="submit" class="ek-action" title="Marcar como predeterminada">☆</button>
                            </form>
                        {% endif %}
                    </td>
                    <td><strong>{{ c.label }}</strong>
                        <br><span class="mono" style="color: var(--ek-ink-3); font-size:11px">#{{ c.id_product_attribute }}</span>
                    </td>
                    <td colspan="4">
                        <form method="post"
                              action="{{ admin_url('productos/' ~ item.id_product ~ '/combinaciones/' ~ c.id_product_attribute ~ '/editar') }}"
                              style="display:flex; gap:8px; align-items:center; justify-content:flex-end">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <input type="text" name="reference" value="{{ c.reference|default('') }}" maxlength="64"
                                   class="ek-stock-input" placeholder="ref." style="width:130px">
                            <input type="text" name="unit_price_impact" value="{{ c.unit_price_impact|default(0) }}"
                                   inputmode="decimal" class="ek-stock-input ek-stock-input--small" placeholder="±€">
                            <input type="number" name="stock" value="{{ c.stock }}" min="0"
                                   class="ek-stock-input ek-stock-input--small">
                            <button type="submit" class="ek-action">Guardar</button>
                            <button type="button" class="ek-action ek-action--danger"
                                    onclick="event.preventDefault(); if(confirm('¿Eliminar esta combinación?')) document.getElementById('del-comb-{{ c.id_product_attribute }}').submit();">
                                Borrar
                            </button>
                        </form>
                        <form method="post" id="del-comb-{{ c.id_product_attribute }}"
                              action="{{ admin_url('productos/' ~ item.id_product ~ '/combinaciones/' ~ c.id_product_attribute ~ '/eliminar') }}"
                              style="display:none">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <small class="ek-field__hint" style="margin-top: 8px; display:block">
            <em>Impacto precio</em> es lo que se SUMA al precio base del producto cuando se elige esta combinación
            (positivo o negativo).
        </small>
    {% else %}
        <p style="color: var(--ek-ink-3); margin: 8px 0 14px">
            Este producto aún no tiene combinaciones. Genera las que necesites usando los grupos de atributos.
        </p>
    {% endif %}

    <h3 style="font-size:13px; margin-top:18px; padding-top:14px; border-top:1px solid var(--ek-line)">+ Generar combinaciones</h3>
    {% if attribute_groups|length == 0 %}
        <p style="color: var(--ek-ink-3)">
            Crea primero grupos de atributos en
            <a href="{{ admin_url('atributos') }}">Atributos y características</a>.
        </p>
    {% else %}
    <p class="ek-field__hint">
        Selecciona los valores que quieres combinar. Se generará el producto cartesiano (3 colores × 2 tallas = 6 combinaciones).
    </p>
    <form method="post"
          action="{{ admin_url('productos/' ~ item.id_product ~ '/combinaciones/generar') }}">
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

        {% for g in attribute_groups %}
            {% if group_values[g.id_attribute_group]|length > 0 %}
                <div style="background: var(--ek-blue-soft); padding: 6px 12px; margin: 8px 0 4px; border-radius: var(--ek-r-sm); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--ek-blue-deep)">
                    <strong>{{ g.name }}</strong>
                    {% if g.public_name and g.public_name != g.name %}<span style="opacity:.7"> · {{ g.public_name }}</span>{% endif %}
                </div>
                <div style="display:flex; gap:14px; flex-wrap:wrap; padding: 6px 14px; margin-bottom: 4px">
                    {% for v in group_values[g.id_attribute_group] %}
                        <label style="display:inline-flex; align-items:center; gap:6px; cursor:pointer; font-size:13px">
                            <input type="checkbox" name="attrs[{{ g.id_attribute_group }}][]" value="{{ v.id_attribute }}">
                            {% if g.group_type == 'color' and v.color %}
                                <span style="display:inline-block; width:14px; height:14px; border-radius:50%; background:{{ v.color }}; border:1px solid var(--ek-line)"></span>
                            {% endif %}
                            {{ v.name }}
                        </label>
                    {% endfor %}
                </div>
            {% endif %}
        {% endfor %}

        <button type="submit" class="ek-btn ek-btn--primary" style="margin-top:14px">Generar combinaciones</button>
    </form>
    {% endif %}
</div>

<div class="ek-panel" id="caracteristicas" style="margin-top:16px">
    <h2>Características asignadas</h2>
    <p class="ek-panel__hint">
        Asigna características descriptivas (potencia, material, dimensiones…) al producto.
        Se gestiona desde <a href="{{ admin_url('caracteristicas') }}">Atributos y características</a>.
    </p>

    {% if product_features|length > 0 %}
    <table class="ek-table" style="margin-top:8px">
        <thead>
            <tr>
                <th>Característica</th>
                <th>Valor</th>
                <th style="width:120px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for pf in product_features %}
            <tr>
                <td><strong>{{ pf.feature_name|default('—') }}</strong></td>
                <td>{{ pf.value|default('—') }}</td>
                <td style="text-align:right">
                    <form method="post"
                          action="{{ admin_url('productos/' ~ item.id_product ~ '/caracteristicas/desasignar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Quitar esta característica del producto?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="id_feature" value="{{ pf.id_feature }}">
                        <button type="submit" class="ek-action ek-action--danger">Quitar</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
        <p style="color: var(--ek-ink-3); margin: 6px 0 14px">Sin características asignadas todavía.</p>
    {% endif %}

    <h3 style="font-size:13px; margin-top:18px; padding-top:14px; border-top:1px solid var(--ek-line)">+ Asignar característica</h3>
    {% if all_features|length == 0 %}
        <p style="color: var(--ek-ink-3)">
            Primero crea características en
            <a href="{{ admin_url('caracteristicas') }}">Atributos y características → Características</a>.
        </p>
    {% else %}
    <form method="post" action="{{ admin_url('productos/' ~ item.id_product ~ '/caracteristicas/asignar') }}"
          class="ek-values-add" style="border-top:0; padding-top:0; align-items:flex-end">
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

        <label class="ek-field" style="margin:0; flex:1; min-width:160px">
            <span>Característica</span>
            <select name="id_feature" id="ek-feat-select" required>
                <option value="0">— Selecciona —</option>
                {% for f in all_features %}
                    <option value="{{ f.id_feature }}">{{ f.name }}</option>
                {% endfor %}
            </select>
        </label>

        <label class="ek-field" style="margin:0; flex:1; min-width:160px">
            <span>Valor predefinido</span>
            <select name="id_feature_value" id="ek-feat-value">
                <option value="0">—</option>
                {% for fid, vals in feature_values %}
                    {% for v in vals %}
                        <option value="{{ v.id_feature_value }}" data-feature="{{ fid }}" hidden>{{ v.value }}</option>
                    {% endfor %}
                {% endfor %}
            </select>
        </label>

        <label class="ek-field" style="margin:0; flex:1; min-width:160px">
            <span>O valor personalizado</span>
            <input type="text" name="custom_value" maxlength="255" placeholder="Texto libre">
        </label>

        <button type="submit" class="ek-btn ek-btn--primary">Asignar</button>
    </form>

    <script>
    (function () {
        const featSel = document.getElementById('ek-feat-select');
        const valSel  = document.getElementById('ek-feat-value');
        if (!featSel || !valSel) return;
        featSel.addEventListener('change', () => {
            const fid = featSel.value;
            valSel.value = '0';
            valSel.querySelectorAll('option').forEach(o => {
                if (o.value === '0') return;
                o.hidden = (o.dataset.feature !== fid);
            });
        });
    })();
    </script>
    {% endif %}
</div>
{% endif %}

<script>
(function () {
    const nameEl = document.getElementById('ek-prod-name');
    const slugEl = document.getElementById('ek-prod-slug');
    if (!nameEl || !slugEl) return;

    let slugTouched = slugEl.value.trim() !== '';
    slugEl.addEventListener('input', () => { slugTouched = true; });

    const slugify = (s) => s
        .toLowerCase().trim()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');

    nameEl.addEventListener('input', () => {
        if (!slugTouched) slugEl.value = slugify(nameEl.value);
    });
})();
</script>
{% endblock %}
