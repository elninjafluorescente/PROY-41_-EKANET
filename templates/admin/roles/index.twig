{% extends 'admin/_layout.twig' %}

{% block content %}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Roles y permisos</h1>
        <p class="ek-page-header__subtitle">
            Define perfiles con permisos granulares por módulo.
            El perfil <strong>SuperAdmin</strong> tiene acceso total por defecto.
        </p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('roles/nuevo') }}">+ Nuevo rol</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Nombre</th>
                <th style="width:120px">Usuarios</th>
                <th style="width:180px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for p in profiles %}
            <tr>
                <td class="mono">{{ p.id_profile }}</td>
                <td>
                    <strong>{{ p.name }}</strong>
                    {% if p.id_profile == 1 %}
                        <span class="ek-pill ek-pill--gold">todos los permisos</span>
                    {% endif %}
                </td>
                <td class="mono">{{ p.employee_count }}</td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('roles/' ~ p.id_profile ~ '/editar') }}">Editar</a>
                    {% if p.id_profile != 1 %}
                    <form method="post" action="{{ admin_url('roles/' ~ p.id_profile ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar el rol \'{{ p.name }}\'?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger"
                                {{ p.employee_count > 0 ? 'disabled title=\"Hay usuarios con este rol\"' : '' }}>
                            Borrar
                        </button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="ek-table__empty">No hay roles definidos.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
