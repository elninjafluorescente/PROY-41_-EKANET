{% extends 'admin/_layout.twig' %}

{% block content %}
{% include 'admin/_partials/tabs_marcas_proveedores.twig' with {tab: 'proveedores'} %}

<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Proveedores</h1>
        <p class="ek-page-header__subtitle">Empresas que suministran producto a Ekanet.</p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('proveedores/nuevo') }}">+ Nuevo proveedor</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Nombre</th>
                <th style="width:90px">Estado</th>
                <th style="width:140px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for s in suppliers %}
            <tr>
                <td class="mono">{{ s.id_supplier }}</td>
                <td><strong>{{ s.name }}</strong></td>
                <td>
                    {% if s.active %}
                        <span class="ek-badge ek-badge--ok">Activo</span>
                    {% else %}
                        <span class="ek-badge ek-badge--muted">Inactivo</span>
                    {% endif %}
                </td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('proveedores/' ~ s.id_supplier ~ '/editar') }}">Editar</a>
                    <form method="post" action="{{ admin_url('proveedores/' ~ s.id_supplier ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar el proveedor \'{{ s.name }}\'?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger">Borrar</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="ek-table__empty">No hay proveedores todavía.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
