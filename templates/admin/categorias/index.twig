{% extends 'admin/_layout.twig' %}

{% block content %}
<div class="ek-page-header">
    <div>
        <h1 class="ek-page-header__title">Categorías</h1>
        <p class="ek-page-header__subtitle">
            Árbol jerárquico del catálogo. Cuelga todo de
            <strong>Inicio</strong> (id = 2). Las categorías se indentan por profundidad.
        </p>
    </div>
    <div class="ek-page-header__actions">
        <a class="ek-btn ek-btn--primary" href="{{ admin_url('categorias/nuevo') }}">+ Nueva categoría</a>
    </div>
</div>

<div class="ek-table-wrap">
    <table class="ek-table">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Nombre</th>
                <th>Slug</th>
                <th style="width:70px">Sub.</th>
                <th style="width:80px">Posición</th>
                <th style="width:90px">Estado</th>
                <th style="width:180px; text-align:right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for c in categories %}
                {% if not c.is_root_category %}
            <tr>
                <td class="mono">{{ c.id_category }}</td>
                <td>
                    <span style="display:inline-block; padding-left: {{ max(0, (c.level_depth - 1) * 22) }}px">
                        {% if c.level_depth >= 2 %}<span class="ek-tree-dash">└</span>{% endif %}
                        <strong>{{ c.name }}</strong>
                        {% if c.id_category == 2 %}<span class="ek-pill ek-pill--gold">inicio</span>{% endif %}
                    </span>
                </td>
                <td class="mono" style="font-size:12px; color: var(--ek-ink-3)">{{ c.link_rewrite }}</td>
                <td class="mono">{{ c.child_count }}</td>
                <td class="mono">{{ c.position }}</td>
                <td>
                    {% if c.active %}
                        <span class="ek-badge ek-badge--ok">Activa</span>
                    {% else %}
                        <span class="ek-badge ek-badge--muted">Inactiva</span>
                    {% endif %}
                </td>
                <td style="text-align:right">
                    <a class="ek-action" href="{{ admin_url('categorias/nuevo?parent=' ~ c.id_category) }}"
                       title="Crear subcategoría dentro de {{ c.name }}">+ Sub.</a>
                    {% if c.id_category != 1 %}
                        <a class="ek-action" href="{{ admin_url('categorias/' ~ c.id_category ~ '/editar') }}">Editar</a>
                    {% endif %}
                    {% if c.id_category != 1 and c.id_category != 2 %}
                    <form method="post" action="{{ admin_url('categorias/' ~ c.id_category ~ '/eliminar') }}"
                          style="display:inline"
                          onsubmit="return confirm('¿Eliminar la categoría \'{{ c.name }}\'?');">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="ek-action ek-action--danger"
                                {{ c.child_count > 0 ? 'disabled title=\"Tiene subcategorías\"' : '' }}>
                            Borrar
                        </button>
                    </form>
                    {% endif %}
                </td>
            </tr>
                {% endif %}
            {% else %}
            <tr><td colspan="7" class="ek-table__empty">No hay categorías todavía.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
